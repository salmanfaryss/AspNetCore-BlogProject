@using Entity.Concrete
@model Message2
@{
    ViewData["Title"] = "InboxMessageDetail";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!DOCTYPE html>
<html>

<head>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>INSPINIA | Mailbox</title>

    <link href="css/bootstrap.min.css" rel="stylesheet">
    <link href="font-awesome/css/font-awesome.css" rel="stylesheet">
    <link href="css/plugins/iCheck/custom.css" rel="stylesheet">
    <link href="css/animate.css" rel="stylesheet">
    <link href="css/style.css" rel="stylesheet">

</head>

<body>

    @* <div id="wrapper">

       

        <div id="page-wrapper" class="gray-bg"> *@
          

            <div class="wrapper wrapper-content">
                <div class="row">
            @await Component.InvokeAsync("AdminMessageMenu")
                   
                    <div class="col-lg-9 animated fadeInRight">
                        <div class="mail-box-header">
                            <div class="float-right tooltip-demo">
                                <a href="mail_compose.html" class="btn btn-white btn-sm" data-toggle="tooltip" data-placement="top" title="Reply"><i class="fa fa-reply"></i> Reply</a>
                                <a href="#" class="btn btn-white btn-sm" data-toggle="tooltip" data-placement="top" title="Print email"><i class="fa fa-print"></i> </a>
                                <a href="mailbox.html" class="btn btn-white btn-sm" data-toggle="tooltip" data-placement="top" title="Move to trash"><i class="fa fa-trash-o"></i> </a>
                            </div>
                            <h2>
                                Mesaj Okuma sayfası
                            </h2>
                            <div class="mail-tools tooltip-demo m-t-md">


                                <h3>
                                    <span class="font-normal">Konu: </span>@Html.DisplayFor(x => x.Subject)
                                </h3>
                                <h5>
                                    <span class="float-right font-normal">@(((DateTime)Model.Date).ToString("dd-MMM-yyyy"))</span>
                                    <span class="font-normal">Kimden: </span>@Html.DisplayFor(x => x.SenderUser.WriterName)
                                </h5>
                            </div>
                        </div>
                        <div class="mail-box">


                            <div class="mail-body">
                                <p>
                                    Merhaba @Html.DisplayFor(x => x.ReceiverUser.WriterName)
                                    <br />
                                    <br />
                                  @Model.Content
                                </p>
                               
                            </div>
                            <div class="mail-attachment">
                                <p>
                                    <span><i class="fa fa-paperclip"></i> 2 attachments - </span>
                                    <a href="#">Yükle</a>
                                    |
                                    <a href="#">Tümünü Görün</a>
                                </p>

                                <div class="attachment">
                                    <div class="file-box">
                                        <div class="file">
                                            <a href="#">
                                                <span class="corner"></span>

                                                <div class="icon">
                                                    <i class="fa fa-file"></i>
                                                </div>
                                                <div class="file-name">
                                                    Document_2014.doc
                                                    <br />
                                                    <small>Added: Jan 11, 2014</small>
                                                </div>
                                            </a>
                                        </div>

                                    </div>
                                    <div class="file-box">
                                        <div class="file">
                                            <a href="#">
                                                <span class="corner"></span>

                                                <div class="image">
                                            <img alt="image" class="img-fluid" src="/inspinia-gh-pages/img/p1.jpg">
                                                </div>
                                                <div class="file-name">
                                                    Italy street.jpg
                                                    <br />
                                                    <small>Added: Jan 6, 2014</small>
                                                </div>
                                            </a>

                                        </div>
                                    </div>
                                    <div class="file-box">
                                        <div class="file">
                                            <a href="#">
                                                <span class="corner"></span>

                                                <div class="image">
                                            <img alt="image" class="img-fluid" src="/inspinia-gh-pages/img/p2.jpg">
                                                </div>
                                                <div class="file-name">
                                                    My feel.png
                                                    <br />
                                                    <small>Added: Jan 7, 2014</small>
                                                </div>
                                            </a>
                                        </div>
                                    </div>
                                    <div class="clearfix"></div>
                                </div>
                            </div>
                            <div class="mail-body text-right tooltip-demo">
                                <a class="btn btn-sm btn-white" href="mail_compose.html"><i class="fa fa-reply"></i> Reply</a>
                                <a class="btn btn-sm btn-white" href="mail_compose.html"><i class="fa fa-arrow-right"></i> Forward</a>
                                <button title="" data-placement="top" data-toggle="tooltip" type="button" data-original-title="Print" class="btn btn-sm btn-white"><i class="fa fa-print"></i> Print</button>
                                <button title="" data-placement="top" data-toggle="tooltip" data-original-title="Trash" class="btn btn-sm btn-white"><i class="fa fa-trash-o"></i> Remove</button>
                            </div>
                            <div class="clearfix"></div>


                        </div>
                    </div>
                </div>
            </div>
            <div class="footer">
                <div class="float-right">
                    10GB of <strong>250GB</strong> Free.
                </div>
                <div>
                    <strong>Copyright</strong> Example Company &copy; 2014-2018
                </div>
            </div>

        @* </div>
    </div> *@

    
</body>

</html>

