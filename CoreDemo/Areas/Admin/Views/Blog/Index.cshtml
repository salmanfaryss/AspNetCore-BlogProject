@using Entity.Concrete
@model List<Blog>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
 
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-3">
                <div class="ibox">
                
                    <div class="ibox-content product-box">

                        <div class="product-imitation">
                            <img src="@item.BlogImage" class="img-fluid product-image" alt="product" style="width: 100%">
                        </div>
                        <div class="product-desc">
                            <span class="product-price">
                                @(((DateTime)item.Date).ToString("dd-MMM-yyyy"))
                            </span>
                            <small class="text-muted">@item.Category.CategoryName</small>
                            <a href="#" class="product-name"> @item.Writer.WriterName</a>



                            <div class="small m-t-xs">
                                @item.BlogContent.Substring(0, item.BlogContent.Substring(0, 130).LastIndexOf(" ")).. .
                            </div>
                            <div class="m-t text-righ">

                                <a href="/Blog/ReadMore/@item.BlogID" class="btn btn-xs btn-outline btn-primary">Devamın Oku <i class="fa fa-long-arrow-right"></i> </a>
                            </div>
                        </div>
                    </div>
                
               
            </div>
        </div>
        }

    </div>
</div>
