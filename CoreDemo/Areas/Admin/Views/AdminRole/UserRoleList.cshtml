@using Entity.Concrete
@model List<AppUser>
@{
    ViewData["Title"] = "UserRoleList";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<br /><br />
<table class="table">
    <thead>
        <tr>
            <th scope="col">#</th>
            <th scope="col">Kullanıcı Adı</th>
            <th scope="col">Kullanıcı</th>
            <th scope="col">Rol Ata</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var item in Model)
        {
            <tr>
                <th scope="row">@item.Id</th>
                <td>@item.NameSurname</td>
                <td>@item.UserName</td>

                <td> <a href="/Admin/AdminRole/AssignRole/@item.Id" class="btn btn-success btn-rounded">Rol Ata</a>   </td>
                
            </tr>
        }
     
      
    </tbody>
</table>
<br />
 <a href="/Admin/AdminRole/Index/" class="btn btn-success btn-rounded">Rol Listesi Dön</a>  
