@using Entity.Concrete
@model List<Blog>
@{
    ViewData["Title"] = "BlogList";
    Layout = "~/Views/Shared/UserLayout.cshtml";
}

<div class="header_top" id="home">
	<nav class="navbar navbar-expand-lg navbar-light bg-light">
		<button class="navbar-toggler navbar-toggler-right mx-auto" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent"
				aria-expanded="false" aria-label="Toggle navigation">
			<span class="navbar-toggler-icon"></span>
		</button>


		<div class="collapse navbar-collapse" id="navbarSupportedContent">
			<ul class="navbar-nav mr-auto">
				<li class="nav-item">
					<a class="nav-link" href="/Blog/BlogList/">
						ANA SAYFA
						<span class="sr-only">(current)</span>
					</a>
				</li>
				<li class="nav-item">
					<a class="nav-link" href="/About/Index/">HAKKIMIZDA</a>
				</li>

				<li class="nav-item">
					<a class="nav-link" href="/Blog/BlogList/">BLOGLAR</a>
				</li>
				<li class="nav-item">
					<a class="nav-link" href="/Contact/Index/">IlETIŞIM</a>
				</li>

			</ul>

			<form asp-controller="Blog" asp-action="BlogList" method="get" class="form-inline my-2 my-lg-0 header-search">
				<input class="form-control mr-sm-2"
					   type="search"
					   placeholder="Aranacak Kelime..."
					   name="search"
					   required />

				<button class="btn btn1 my-2 my-sm-0" type="submit">
					<i class="fas fa-search"></i>
				</button>
			</form>


		</div>
	</nav>

</div>

<section class="main-content-w3layouts-agileits">
	<div class="container">
		<h3 class="tittle">Blog Posts</h3>
		<div class="inner-sec">
			<!--left-->
			<div class="left-blog-info-w3layouts-agileits text-left">
				<div class="row">
					@foreach (var item in Model)
					{


						<div class="col-lg-4 card">
							<a href="/Blog/ReadMore/@item.BlogID">
								<img src="@item.BlogImage" class="card-img-top img-fluid" alt="">
							</a>
							<div class="card-body">
								<ul class="blog-icons my-4">
									<li>
										<a href="#">
											<i class="far fa-calendar-alt"></i> @(((DateTime)item.Date).ToString("dd-MMM-yyyy"))
										</a>
									</li>
									<li class="mx-2">
										<a href="#">
											<i class="far fa-comment"></i> 21
										</a>
									</li>
									<li>
										<a href="#">
											<i class="fas fa-eye"></i> @item.Category.CategoryName
										</a>
									</li>

								</ul>
								<h5 class="card-title">
									<a href="/Blog/ReadMore/@item.BlogID">@item.BlogTitle</a>
								</h5>
								<p class="card-text mb-3">@item.BlogContent.Substring(0,item.BlogContent.Substring(0,130).LastIndexOf(" ")).. </p>
								<a href="/Blog/ReadMore/@item.BlogID" class="btn btn-primary read-m">Devamını Oku</a>
							</div>
						</div>
					}
				</div>
				<!--//left-->
			</div>
		</div>
	</div>
</section>
