@using Entity.Concrete
@model List<Blog>


@{
    ViewData["Title"] = "BlogListByWriter";
    Layout = "~/Views/Shared/_WriterLayout.cshtml";
    string text = "";
    string color = "";
}


<div class="main-panel">
    <div class="content-wrapper">
        <div class="page-header">
            <h3 class="page-title"> Yazarın Blogları </h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="#">Tables</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Basic tables</li>
                </ol>
            </nav>
        </div>
        <div class="row">
            <div class="col-lg-12 grid-margin stretch-card">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title">Yazarın Blogları</h4>
                        <p class="card-description">
                            Add class <code>.table</code>
                        </p>
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Blog Başlığı</th>
                                    <th>Oluşturma Tarihi</th>
                                    <th>Kategori</th>
                                    <th>Durumu</th>
                                    <th>Güncelleme</th>
                                    <th>Aktif Yap</th>
                                    <th>Pasif Yap</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if(Model != null)
                                {
                                    
                                    foreach (var item in Model)
                                    {
                                        if(item.Status == true)
                                        {
                                            text = "Yayınladı";
                                            color = "badge badge-success";
                                        }
                                        else
                                        {
                                            text = "Yayınlamadı";
                                            color = "badge badge-danger";
                                        }
                                        <tr>
                                            <td>@item.BlogID</td>
                                            <td>@item.BlogTitle</td>
                                            <td>@(((DateTime)item.Date).ToString("dd-MMM-yyyy"))</td>
                                             <td>@item.Category.CategoryName</td> 
                                            <td><label class="@color">@text</label></td>
                                            <td> <a href="/Blog/UpdateBlog/@item.BlogID" class="btn btn-gradient-warning btn-rounded btn-fw">Güncelleme</a>  </td>
                                            <td> <a href="/Blog/ChangeBlogStatusToTrue/@item.BlogID" class="btn btn-gradient-success btn-rounded btn-fw">Aktif Yap</a>  </td>
                                            <td> <a href="/Blog/ChangeBlogStatusToFalse/@item.BlogID" class="btn btn-gradient-danger btn-rounded btn-fw">Pasif Yap</a>  </td>
                                        </tr>
                                    }
                                }
                                


                            </tbody>
                        </table>
                        <br />
                        <a href="/Blog/CreateBlog/" class="btn btn-gradient-primary btn-rounded btn-fw"> Yeni Blog Oluştur </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
    <!-- content-wrapper ends -->
    <!-- partial:../../partials/_footer.html -->
    @await Component.InvokeAsync("WriterPanelFooterComponent")
    <!-- partial -->
</div>

