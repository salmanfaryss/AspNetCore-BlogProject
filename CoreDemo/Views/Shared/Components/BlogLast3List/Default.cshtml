<div class="col-lg-4 footer-grid-agileits-w3ls text-left">
	@using Entity.Concrete
	@model List<Blog>
	<div class="tech-btm">
		<h3>Son Postlar</h3>
		<div class="blog-grids row mb-3">
			@foreach (var item in Model)
			{
				<div class="col-md-5 blog-grid-left">
					<a href="/ReadMore/Blog/@item.BlogID">
						<img src="@item.BlogImage" class="card-img-top img-fluid" alt="">
					</a>
				</div>

				<div class="col-md-7 blog-grid-right">

				<h5>
					<a href="/ReadMore/Blog/@item.BlogID">@item.BlogContent.Substring(0,100) </a>
				</h5>
				<div class="sub-meta">
					<span>
						<i class="far fa-clock"></i> @(((DateTime)item.Date).ToString("dd-MMM-yyyy"))
					</span>
				</div>
			</div>
			}
		</div>

	</div>
</div>