<div class="col-lg-3">
    <div class="ibox ">
        <div class="ibox-content mailbox-content">
            <div class="file-manager">
                <a class="btn btn-block btn-primary compose-mail" href="/Admin/Message/NewMessage/">Mesaj Oluştur</a>
                <div class="space-25"></div>
                <h5>Mesaj kutusu</h5>
                <ul class="folder-list m-b-md" style="padding: 0">
                    <li><a href="/Admin/Message/Inbox/"> <i class="fa fa-inbox "></i> Gelen mesajlar <span class="label label-warning float-right">@ViewBag.InboxId</span> </a></li>
                    <li><a href="/Admin/Message/Sendbox/"> <i class="fa fa-envelope-o"></i>Giden mesajlar <span class="label label-warning float-right">@ViewBag.senboxId</span>   </a></li>
                    <li><a href="mailbox.html"> <i class="fa fa-certificate"></i> Önemli</a></li>
                    <li><a href="mailbox.html"> <i class="fa fa-file-text-o"></i>Taslaklar  <span class="label label-danger float-right">2</span></a></li>
                    <li><a href="mailbox.html"> <i class="fa fa-trash-o"></i> Çöp kutusu</a></li>
                </ul>
                <h5>Kategoriler</h5>
                <ul class="category-list" style="padding: 0">
                    <li><a href="#"> <i class="fa fa-circle text-navy"></i> İş </a></li>
                    <li><a href="#"> <i class="fa fa-circle text-danger"></i> Dökumanlar</a></li>
                    <li><a href="#"> <i class="fa fa-circle text-primary"></i> Sosyal</a></li>
                    <li><a href="#"> <i class="fa fa-circle text-info"></i> Tanıtımlar</a></li>
                    <li><a href="#"> <i class="fa fa-circle text-warning"></i> Taleplar</a></li>
                </ul>



            </div>
        </div>
